  "firstName": "Ana",
  "lastName": "Anic",
  "address": "Test address 2b",
  "partnerNumber": "22222222222222222221",
  "croatianPIN": "1234567890",
  "partnerTypeId": 1,
  "createByUser": "admin@example.com",
  "isForeign": false,
  "externalCode": "EXT9999998",
  "gender": "F"
}

